# MiniSaaS Environment Variables
# Copy these to your xCloud Settings -> Environment Variables

PORT=3000
JWT_SECRET=your_super_secret_key_here

# MySQL Database (Get these from xCloud Database tab)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=minisaas

# AI API Key (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Socket Settings
NODE_ENV=production
