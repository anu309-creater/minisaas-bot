# MiniSaaS Environment Variables
# Copy these to your xCloud Settings -> Environment Variables

PORT=3000
JWT_SECRET=your_super_secret_key_here

# MySQL Database (Required for xCloud/Production)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=minisaas

# SQLite Database (Used for local dev if MySQL vars are missing)
# DB_PATH=./database.sqlite

# AI API Key (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Socket Settings
NODE_ENV=production
